# Application
DEBUG=true
ENVIRONMENT=development

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@host/database?sslmode=require

# Vector Database (Qdrant Cloud)
QDRANT_URL=https://your-cluster.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=e4bde306-2099-4a92-8901-2bda38cfddc8|gKbTlWvZ5o4hTFhZzQ3rAncxeHRrrhmqmb8OHVQyh3_xWvrBcXGCeg

# AI Provider (choose: "gemini" or "openai")
AI_PROVIDER=gemini

# Gemini (recommended - default)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-exp

# OpenAI (alternative)
