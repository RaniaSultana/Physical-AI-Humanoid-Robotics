# Authentication
JWT_SECRET=generate-a-secure-random-string-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# OAuth Providers (optional)
